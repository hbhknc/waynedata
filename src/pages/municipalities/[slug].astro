---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import DataNotice from '../../components/DataNotice.astro';
import SectionCard from '../../components/SectionCard.astro';
import { municipalities } from '../../data/municipalities';

export function getStaticPaths() {
  return municipalities.map((municipality) => ({
    params: { slug: municipality.slug },
    props: { municipality }
  }));
}

const { municipality } = Astro.props;
---

<BaseLayout
  title={`${municipality.name} | Wayne Public Safety Monitor`}
  description={`${municipality.name} public safety profile.`}
>
  <PageHero
    eyebrow="Municipality profile"
    title={municipality.name}
    intro={municipality.agencyNotes}
  />

  <section class="section">
    <div class="container">
      <DataNotice title="Municipality data status" />
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <SectionCard title="Initial focus areas">
        <ul>
          {municipality.focus.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </SectionCard>

      <SectionCard title="Rollout status">
        <p>{municipality.status}</p>
        <p>
          This profile expands over time with municipality-specific charts, source links, methodology notes, and local
          budget or service-coverage context.
        </p>
      </SectionCard>
    </div>
  </section>
</BaseLayout>
