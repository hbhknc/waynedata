---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { municipalities, municipalityStatusLegend } from '../../data/municipalities';
---

<BaseLayout title="Municipalities | Wayne Public Safety Monitor" description="Municipality profile pages and rollout plan.">
  <PageHero
    eyebrow="Municipalities"
    title="Local profile pages"
    intro="Each municipality page should combine trend charts, context notes, source links, and clear caveats. Start with the strongest candidates and expand once the countywide data model is stable."
  />

  <section class="section">
    <div class="container table-panel">
      <table>
        <thead>
          <tr>
            <th>Municipality</th>
            <th>Status</th>
            <th>Focus</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {municipalities.map((municipality) => (
            <tr>
              <td>
                <a href={`/municipalities/${municipality.slug}`}>{municipality.name}</a>
              </td>
              <td>{municipality.status}</td>
              <td>{municipality.focus.join(', ')}</td>
              <td>{municipality.agencyNotes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section">
    <div class="container panel">
      <h2>Status legend</h2>
      <ul>
        {municipalityStatusLegend.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
