---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionCard from '../components/SectionCard.astro';
---

<BaseLayout title="Methodology | Wayne Public Safety Monitor" description="Methodology and source notes.">
  <PageHero
    eyebrow="Methodology"
    title="How the project handles data"
    intro="This page is essential to the credibility of the site. It should make clear where the data came from, how it was cleaned, what the site does and does not claim, and where readers should be cautious."
  />

  <section class="section">
    <div class="container two-col">
      <SectionCard title="Methodology checklist">
        <ul>
          <li>List the underlying sources for every recurring dataset.</li>
          <li>Describe update cadence and publication lag.</li>
          <li>Explain rate calculations and denominators.</li>
          <li>Flag missing data, reporting changes, and definitional inconsistencies.</li>
          <li>Link directly to source documents when available.</li>
        </ul>
      </SectionCard>

      <SectionCard title="Standards language">
        <ul>
          <li>Separate raw data from interpretation.</li>
          <li>Use plain language for readers without technical backgrounds.</li>
          <li>Avoid implying causation without evidence.</li>
          <li>Correct errors promptly and visibly.</li>
          <li>Document material revisions to datasets.</li>
        </ul>
      </SectionCard>
    </div>
  </section>
</BaseLayout>
