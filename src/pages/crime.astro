---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';

const charts = [
  {
    title: 'Violent crime rate',
    subtitle: 'Incidents per 100,000 residents',
    chart: `2019 | 405\n2020 | 429\n2021 | 447\n2022 | 434\n2023 | 421`
  },
  {
    title: 'Property crime rate',
    subtitle: 'Incidents per 100,000 residents',
    chart: `2019 | 2,867\n2020 | 2,744\n2021 | 2,590\n2022 | 2,471\n2023 | 2,438`
  },
  {
    title: 'Clearance rate',
    subtitle: 'Share of index crimes cleared',
    chart: `2019 | ████████▎ 41%\n2020 | ████████▌ 42%\n2021 | ████████▉ 44%\n2022 | ████████▋ 43%\n2023 | █████████ 45%`
  },
  {
    title: 'Calls for service',
    subtitle: 'Sheriff + municipal combined (thousands)',
    chart: `2019 | ███████████████ 156k\n2020 | ███████████████▎ 158k\n2021 | ███████████████▌ 160k\n2022 | ███████████████▏ 157k\n2023 | ███████████████ 156k`
  }
];
---

<BaseLayout title="Crime | Wayne Data Terminal" description="Crime dashboard with four charts.">
  <PageShell
    section="Crime"
    title="Crime signals"
    intro="Four core indicators for trend monitoring, without narrative bloat."
    charts={charts}
  />
</BaseLayout>
