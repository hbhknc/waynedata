---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import { buildSeriesChart, barForValue, formatNumber, MAX_BAR_WIDTH } from '../lib/terminalChart';

import violentSeries from '../data/crime/wayne-county/violent-crime.series.json';
import violentSummary from '../data/crime/wayne-county/violent-crime.summary.json';
import indexSeries from '../data/crime/wayne-county/index-crime-rate.series.json';
import indexSummary from '../data/crime/wayne-county/index-crime-rate.summary.json';
import propertySeries from '../data/crime/wayne-county/property-crime-rate.series.json';
import propertySummary from '../data/crime/wayne-county/property-crime-rate.summary.json';

type SeriesPoint = {
  year: number;
  rate: number;
  partial?: boolean;
};

const buildRateSeries = (points: SeriesPoint[], years = 8) =>
  buildSeriesChart(
    points.slice(-years).map((point) => ({
      label: String(point.year),
      value: point.rate,
      note: point.partial ? '*' : undefined
    })),
    (value) => formatNumber(value, 1)
  );

const buildSummaryChart = () => {
  const summaries = [
    { label: 'Violent', data: violentSummary },
    { label: 'Index', data: indexSummary },
    { label: 'Property', data: propertySummary }
  ];

  const currentRates = summaries.map(({ data }) => data.current_rate);
  const minRate = Math.min(...currentRates);
  const maxRate = Math.max(...currentRates);

  return summaries
    .map(({ label, data }) => {
      const bar = barForValue(data.current_rate, minRate, maxRate, MAX_BAR_WIDTH);
      return `${label.padEnd(8)} | ${bar} | ${data.current_year}: ${formatNumber(data.current_rate, 1)} | 5Y ${data.five_year_change_pct}%`;
    })
    .join('\n');
};

const charts = [
  {
    title: 'Violent crime rate (NCSBI Table 6)',
    subtitle: 'Wayne County annual rate per 100,000 residents (last 8 years)',
    chart: buildRateSeries(violentSeries.points)
  },
  {
    title: 'Index crime rate (NCSBI Table 6)',
    subtitle: 'Wayne County annual rate per 100,000 residents (last 8 years)',
    chart: buildRateSeries(indexSeries.points)
  },
  {
    title: 'Property crime rate (NCSBI Table 6)',
    subtitle: 'Wayne County annual rate per 100,000 residents (last 8 years)',
    chart: buildRateSeries(propertySeries.points)
  },
  {
    title: 'Current year snapshot from summaries',
    subtitle: '2024 level + five-year change (%)',
    chart: `${buildSummaryChart()}\n\n* 2018 value in source series is flagged as partial-year data.`
  }
];
---

<BaseLayout title="Crime | Wayne Data Terminal" description="Crime dashboard with Wayne County NCSBI annual rate data.">
  <PageShell
    section="Crime"
    title="Crime signals"
    intro="Sourced from NCSBI annual summaries (Table 6). Displaying real Wayne County series values; 2018 is flagged as partial-year in source reporting."
    charts={charts}
  />
</BaseLayout>
