---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricCard from '../components/MetricCard.astro';
import SectionCard from '../components/SectionCard.astro';
import DataNotice from '../components/DataNotice.astro';
import { homepageCards, launchRoadmap, site } from '../data/site';
import { launchMetrics } from '../data/metrics';
import { municipalities } from '../data/municipalities';
---

<BaseLayout title={`${site.name} | ${site.tagline}`} description={site.mission}>
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__panel">
        <p class="eyebrow">Wayne County public safety data</p>
        <h1>{site.name}</h1>
        <p class="hero__lede">{site.tagline}</p>
        <p>
          {site.mission}
        </p>
        <div class="hero__actions">
          <a class="button" href="/county-dashboard">Explore the county dashboard</a>
          <a class="button--secondary" href="/methodology">Review methodology</a>
        </div>
      </div>

      <aside class="hero__aside">
        <p class="kicker">Launch priorities</p>
        <ul class="list-reset">
          {launchRoadmap.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__heading">
        <div>
          <h2>Project guardrails</h2>
          <p>The site architecture is set up to emphasize trust, restraint, and clear sourcing from day one.</p>
        </div>
      </div>
      <div class="metric-grid">
        {launchMetrics.map((metric) => <MetricCard {...metric} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <DataNotice title="Data publication status" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__heading">
        <div>
          <h2>Core sections</h2>
          <p>Version 1 is organized around dashboards, municipality pages, reports, and methodology.</p>
        </div>
      </div>
      <div class="grid">
        {homepageCards.map((card) => <SectionCard {...card} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__heading">
        <div>
          <h2>Municipality rollout</h2>
          <p>Start with the highest-value local pages, then expand once the data pipeline stabilizes.</p>
        </div>
      </div>
      <div class="table-panel">
        <table>
          <thead>
            <tr>
              <th>Municipality</th>
              <th>Status</th>
              <th>Initial focus</th>
            </tr>
          </thead>
          <tbody>
            {municipalities.map((municipality) => (
              <tr>
                <td>
                  <a href={`/municipalities/${municipality.slug}`}>{municipality.name}</a>
                </td>
                <td>{municipality.status}</td>
                <td>{municipality.focus.join(', ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
