---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';

const charts = [
  {
    title: 'Publishing cadence',
    subtitle: 'Expected update rhythm by section',
    chart: `overview   | weekly\ncrime      | monthly\neducation  | quarterly\ngovernment | monthly`
  },
  {
    title: 'Source mix',
    subtitle: 'Current weighting of source categories',
    chart: `Administrative records | ████████████ 48%\nState datasets          | ██████████ 39%\nFOIA/public requests    | ████ 13%`
  },
  {
    title: 'Data QA checklist',
    subtitle: 'Completion rate in the current cycle',
    chart: `Schema checks   | complete\nMissing data   | complete\nOutlier review | in progress\nPeer review    | queued`
  },
  {
    title: 'Coverage footprint',
    subtitle: 'Topic distribution of posted briefs',
    chart: `crime      | 42%\neducation  | 25%\ngovernment | 23%\nother      | 10%`
  }
];
---

<BaseLayout title="About | Wayne Data Terminal" description="About the project and how data is handled.">
  <PageShell
    section="About"
    title="What this project is"
    intro="Wayne Data Terminal is intentionally austere: coding typography, narrow scope, and explicit limits."
    charts={charts}
  />
</BaseLayout>
