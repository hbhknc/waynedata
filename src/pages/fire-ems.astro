---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionCard from '../components/SectionCard.astro';
import DataNotice from '../components/DataNotice.astro';
---

<BaseLayout title="Fire & EMS | Wayne Public Safety Monitor" description="Fire and EMS section scaffold for Wayne County.">
  <PageHero
    eyebrow="Fire & EMS"
    title="Emergency response tracking"
    intro="Use this section for incident volume, call-type patterns, response context, and service-area coverage notes. It should complement the crime section rather than duplicate it."
  />

  <section class="section">
    <div class="container two-col">
      <SectionCard
        title="Recommended launch modules"
        description="The early build should focus on metrics that are understandable and sustainable to maintain."
      >
        <ul>
          <li>Annual incident counts</li>
          <li>Call-type distribution</li>
          <li>Municipality or district trend snapshots</li>
          <li>Seasonal change notes</li>
          <li>Document links for call logs or annual reports</li>
        </ul>
      </SectionCard>

      <SectionCard
        title="Data interpretation notes"
        description="Fire and EMS data often requires careful explanation because incident categories, mutual aid, and service boundaries can distort quick comparisons."
      >
        <ul>
          <li>Explain jurisdictional coverage on each page.</li>
          <li>Separate EMS volume from fire-specific incidents when possible.</li>
          <li>Flag methodology changes or incomplete datasets.</li>
          <li>Avoid mixing call volume with performance claims unless the evidence supports it.</li>
        </ul>
      </SectionCard>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <DataNotice title="Fire and EMS data placeholder" />
    </div>
  </section>
</BaseLayout>
