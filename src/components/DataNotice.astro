---
interface Props {
  title?: string;
}

const { title = 'Data status' } = Astro.props;
---

<div class="data-notice" role="note" aria-label={title}>
  <p class="data-notice__title">{title}</p>
  <p>
    This section is updated as source records are released and verified. Figures and notes are posted only after they
    pass the project&apos;s sourcing and methodology checks.
  </p>
</div>
