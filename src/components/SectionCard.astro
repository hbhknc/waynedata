---
interface Props {
  title: string;
  description?: string;
  href?: string;
  ctaLabel?: string;
}

const { title, description, href, ctaLabel = 'View section' } = Astro.props;
---

<article class="section-card">
  <h2>{title}</h2>
  {description && <p>{description}</p>}
  {href && (
    <p>
      <a class="text-link" href={href}>
        {ctaLabel}
      </a>
    </p>
  )}
  <slot />
</article>
