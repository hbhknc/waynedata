---
interface Props {
  title: string;
  eyebrow?: string;
  intro: string;
}

const { title, eyebrow, intro } = Astro.props;
---

<section class="page-hero">
  <div class="container narrow">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="page-hero__intro">{intro}</p>
  </div>
</section>
